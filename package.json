{
  "name": "glowai",
  "version": "1.0.0",
  "description": "GlowAI — AI Skin Analysis powered by Claude Vision",
  "main": "electron/main.js",
  "author": "Christopher Cadger <cadger808@codeberg.org>",
  "license": "UNLICENSED",
  "scripts": {
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "electron-builder --linux",
    "electron:dist": "electron-builder --linux AppImage rpm",
    "cap:sync": "npx cap copy && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/camera": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "minimatch": ">=10.2.3",
    "tar": ">=7.5.11"
  },
  "build": {
    "appId": "com.cadger808.glowai",
    "productName": "GlowAI",
    "copyright": "Copyright © 2025 Christopher Cadger",
    "directories": {
      "output": "dist-electron",
      "buildResources": "icons"
    },
    "files": [
      "index.html",
      "offline.html",
      "api-client.js",
      "magic-link.js",
      "app.js",
      "scan.js",
      "advisor.js",
      "routine.js",
      "progress.js",
      "onboarding.js",
      "avatar-widget.js",
      "share-widget.js",
      "sw.js",
      "manifest.json",
      "icons/**",
      "electron/**",
      "!node_modules/**",
      "!android/**",
      "!www/**",
      "!dist-electron/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "rpm"
      ],
      "category": "Utility",
      "icon": "icons/icon-512.png",
      "desktop": {
        "Name": "GlowAI",
        "Comment": "AI Skin Analysis",
        "Categories": "Utility;Health"
      }
    },
    "publish": {
      "provider": "generic",
      "url": "https://codeberg.org/cadger808/glowai/releases/download/latest/"
    }
  }
}

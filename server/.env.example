# Copy to .env and fill in values — NEVER commit .env to git

# Your Anthropic API key (stays server-side, never exposed to clients)
ANTHROPIC_API_KEY=sk-ant-...

# Random secret for signing JWTs — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# SQLite (default) or swap to PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/glowai
DATABASE_URL=sqlite:///./glowai.db

# CORS — comma-separated allowed origins (no trailing slash)
# ALLOWED_ORIGINS=https://cadger808.codeberg.page,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
